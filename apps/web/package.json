{
  "name": "@hushbox/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsgo --noEmit && tsgo --noEmit -p tsconfig.native-tests.json",
    "test": "../../scripts/with-env vitest run",
    "test:watch": "../../scripts/with-env vitest",
    "test:coverage": "../../scripts/with-env vitest run --coverage",
    "asset:sync": "npx @capacitor/assets generate --assetPath resources/generated --ios --android",
    "cap:sync": "cap sync",
    "cap:build:ios": "vite build && cap sync ios",
    "cap:build:android": "vite build && cap sync android",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/network": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.3",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capgo/capacitor-updater": "^8.45.3",
    "@hushbox/crypto": "workspace:*",
    "@hushbox/realtime": "workspace:*",
    "@hushbox/ui": "workspace:*",
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-router": "^1.168.21",
    "framer-motion": "^12.38.0",
    "hono": "^4.12.12",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.8.0",
    "mermaid": "^11.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-qrcode-logo": "^4.0.0",
    "react-virtuoso": "^4.18.4",
    "recharts": "^3.8.1",
    "shiki": "^4.0.2",
    "streamdown": "^2.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.0",
    "@hushbox/api": "workspace:*",
    "@hushbox/config": "workspace:*",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query-devtools": "^5.99.0",
    "@tanstack/router-plugin": "^1.167.22",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "wrangler": "^4.82.2"
  }
}
