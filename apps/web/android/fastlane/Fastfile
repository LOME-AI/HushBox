default_platform(:android)

platform :android do
  desc "Build signed AAB (no upload)"
  lane :build_aab do
    gradle(
      task: "bundle",
      build_type: "Release",
    )
  end

  desc "Build signed APK (no upload)"
  lane :build_apk do
    gradle(
      task: "assemble",
      build_type: "Release",
    )
  end

  desc "Upload an already-built AAB to Play Store (track: via :track option, defaults to production)"
  lane :upload_aab do |options|
    track = options[:track] || "production"

    upload_to_play_store(
      track: track,
      aab: "app/build/outputs/bundle/release/app-release.aab",
      json_key_data: ENV["PLAY_STORE_JSON_KEY"],
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end
end
