---
import BlogLayout from '../../layouts/BlogLayout.astro';
import LandingHeader from '../../components/LandingHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import PageHero from '../../components/PageHero.astro';
import BlogPostCard from '../../components/blog/BlogPostCard.astro';
import { BlogSearch } from '../../components/blog/BlogSearch';
import { getPublishedPosts, getAllTags, BLOG_DESCRIPTION } from '../../lib/blog';

const allPosts = await getPublishedPosts();
const allTags = getAllTags(allPosts);

const tagCounts: Record<string, number> = {};
for (const post of allPosts) {
  for (const tag of post.data.tags) {
    tagCounts[tag] = (tagCounts[tag] ?? 0) + 1;
  }
}

const BLOG_CIPHER_MESSAGES: readonly string[] = [
  'Open Notebook',
  'Thinking Out Loud',
  'Built In Public',
  'Behind The Cipher',
  'Read Before You Trust',
  'Posts From The Build',
  'How It Works, Documented',
  'Showing Our Work',
];
---

<BlogLayout title="Blog" description={BLOG_DESCRIPTION}>
  <LandingHeader />

  <main class="flex-1 pt-20">
    <PageHero title="Blog" messages={BLOG_CIPHER_MESSAGES} />

    <section class="mx-auto max-w-5xl px-6 pb-12">
      <div class="space-y-8">
        <BlogSearch allTags={allTags} tagCounts={tagCounts} client:load />

        {
          allPosts.length > 0 && (
            <div class="grid gap-6 pt-4 md:grid-cols-2">
              {allPosts.map((post) => (
                <BlogPostCard post={post} />
              ))}
            </div>
          )
        }

        {
          allPosts.length === 0 && (
            <p class="text-muted-foreground py-12 text-center">No posts yet. Check back soon.</p>
          )
        }
      </div>
    </section>
  </main>

  <SiteFooter />
</BlogLayout>
