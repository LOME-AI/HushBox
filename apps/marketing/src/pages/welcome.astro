---
import { ROUTES } from '@hushbox/shared/routes';
import { SHIPPED_FEATURES, COMING_SOON_FEATURES, COMPARISON_ROWS } from '@hushbox/shared';
import {
  buttonVariants,
  CipherWall,
  ScrollReveal,
  DataGrid,
  FeeBreakdown,
  CostPieChart,
} from '@hushbox/ui';
import { EncryptionDemo } from '../components/encryption-demo';
import { fetchModels, fetchZdrModelIds, processModels } from '@hushbox/shared/models';
import LandingLayout from '../layouts/LandingLayout.astro';
import LandingHeader from '../components/LandingHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import PillarCard from '../components/PillarCard.astro';
import TrustCard from '../components/TrustCard.astro';
import CostComparison from '../components/CostComparison.astro';
import FeatureCard from '../components/FeatureCard.astro';
import ModelProviderStrip from '../components/ModelProviderStrip.astro';
import { calculateMonthlyCost } from '../lib/calculate-cost';
import { extractProviders } from '../lib/extract-providers';
let models: Awaited<ReturnType<typeof processModels>>['models'] = [];

try {
  const [rawModels, zdrIds] = await Promise.all([fetchModels(), fetchZdrModelIds()]);
  const processed = processModels(rawModels, zdrIds);
  models = processed.models;
} catch {
  // Build continues with empty data — page renders with fallback values
}

const costData = calculateMonthlyCost(models);
const providers = extractProviders(models);
const modelCount = models.length;

/** Map shared comparison rows to DataGrid format */
const comparisonRows = COMPARISON_ROWS.map((row) => ({
  label: row.label,
  values: [row.others ? 'Yes' : 'No', row.hushbox ? 'Yes' : 'No'],
}));

/**
 * Convert PascalCase Lucide icon name to kebab-case filename.
 * Must match the logic in scripts/generate-icons.ts.
 */
function toKebabCase(name: string): string {
  return name
    .replaceAll(/([a-z0-9])([A-Z])/g, '$1-$2')
    .replaceAll(/([A-Z])([A-Z][a-z])/g, '$1-$2')
    .toLowerCase();
}

/** Resolve a feature's Lucide icon to the path of its generated SVG file */
function iconPath(lucideIcon: string): string {
  return `@hushbox/ui/assets/icons/${toKebabCase(lucideIcon)}.svg`;
}
---

<LandingLayout
  title="One Interface. Every AI Model. Private."
  description="Access GPT, Claude, Gemini, and dozens more from one encrypted workspace. Your conversations stay yours."
>
  <LandingHeader />

  {/* ===== HERO ===== */}
  <section class="relative flex min-h-svh items-center justify-center overflow-hidden">
    <style is:inline>
      /* Override Astro's display:contents so CipherWall can read parent dimensions */
      [data-cipher-bg] > astro-island {
        display: block;
        width: 100%;
        height: 100%;
      }
      @keyframes bounce-arrow {
        0%,
        100% {
          transform: translateY(0);
        }
        50% {
          transform: translateY(8px);
        }
      }
      .scroll-arrow {
        animation: bounce-arrow 2s ease-in-out infinite;
        transition: opacity 0.3s;
      }
    </style>
    <div class="absolute inset-0" data-cipher-bg>
      <CipherWall client:load fadeMask="radial" fadeMaskTarget="[data-hero-content]" />
    </div>
    <div class="relative z-10 mx-auto max-w-3xl px-6 text-center" data-hero-content>
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl">
        One interface.<br />
        Every feature.<br />
        <span class="text-primary">Private.</span>
      </h1>
      <p class="text-foreground mx-auto mt-6 max-w-xl text-lg sm:text-xl">
        Access the world's leading AI models from one private workspace. Your conversations stay
        yours.
      </p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href={ROUTES.CHAT} class={buttonVariants({ size: 'lg' })}> Try HushBox Free </a>
        <a
          href="#pillars"
          class={`scroll-to-pillars ${buttonVariants({ variant: 'ghost', size: 'lg' })}`}
        >
          See How It Works &rarr;
        </a>
      </div>
      <p class="text-foreground mt-4 text-sm">No account required to try.</p>
    </div>
    <a
      id="scroll-arrow"
      href="#pillars"
      aria-label="Scroll to learn more"
      class="scroll-arrow scroll-to-pillars absolute bottom-16 left-1/2 -translate-x-1/2 cursor-pointer"
    >
      <svg class="text-primary h-16 w-16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"
        ></path>
      </svg>
    </a>
    <script is:inline>
      (function () {
        var arrow = document.getElementById('scroll-arrow');
        if (!arrow) return;
        window.addEventListener(
          'scroll',
          function () {
            arrow.style.opacity = window.scrollY > 50 ? '0' : '1';
          },
          { passive: true }
        );
      })();
      (function () {
        var links = document.querySelectorAll('.scroll-to-pillars');
        links.forEach(function (link) {
          link.addEventListener('click', function (e) {
            var target = document.getElementById('pillars');
            if (!target) return;
            e.preventDefault();
            var offset = target.getBoundingClientRect().top + window.scrollY - 60;
            window.scrollTo({ top: offset, behavior: 'smooth' });
          });
        });
      })();
    </script>
  </section>

  {/* ===== THREE PILLARS ===== */}
  <section id="pillars" class="py-12">
    <div class="mx-auto max-w-5xl px-6">
      <ScrollReveal client:visible>
        <div class="grid gap-6 md:grid-cols-3">
          <PillarCard
            title="Privacy"
            description="Your conversations stay yours. We work exclusively with AI providers that guarantee zero data retention. Privacy isn't a feature. It's the foundation."
          />
          <PillarCard
            title="Innovation"
            description="You shouldn't have to choose between powerful and principled. We build everything you need, as fast as you need it. We ship fast and we don't stop."
          />
          <PillarCard
            title="Transparency"
            description="Every single line of code is open source. Our pricing is public. A 15% fee, broken down to the penny. No subscriptions. You only pay for what you use. You don't have to trust our promises. You can read our code."
          />
        </div>
      </ScrollReveal>
    </div>
  </section>

  {/* ===== PRIVACY PROOF ===== */}
  <section id="how-it-works" class="py-12">
    <div class="mx-auto max-w-5xl px-6">
      <ScrollReveal client:visible>
        <h2 class="text-center text-3xl font-bold tracking-tight sm:text-4xl">
          Privacy you can verify
        </h2>
        <div class="mt-12 grid gap-6 sm:grid-cols-2">
          <TrustCard
            title="Your Messages, Your Key"
            description="Only your devices can read your conversations. Without your password, your data is inaccessible. Even to us."
          />
          <TrustCard
            title="Zero-Knowledge Password"
            description="Your password never leaves your device. We use OPAQUE, the state of the art in password security. We couldn't see it if we tried."
          />
          <TrustCard
            title="Zero Data Retention"
            description="We work exclusively with AI providers that guarantee zero data retention. Your messages are processed and forgotten. Never stored. Never trained on."
          />
          <TrustCard
            title="Anonymous"
            description="AI providers see HushBox. They don't see you. Your identity is never attached to your conversations."
          />
        </div>
      </ScrollReveal>

      <ScrollReveal client:visible delay={200}>
        <div class="mt-12">
          <EncryptionDemo client:visible />
        </div>
      </ScrollReveal>
    </div>
  </section>

  {/* ===== COST COMPARISON ===== */}
  {
    costData.monthlyCost > 0 && (
      <section class="py-12">
        <div class="mx-auto max-w-5xl px-6">
          <ScrollReveal client:visible>
            <h2 class="text-center text-3xl font-bold tracking-tight sm:text-4xl">
              Same models. A fraction of the cost
            </h2>
            <p class="text-foreground mt-3 text-center">
              Based on {costData.messagesPerDay} messages per day:
            </p>
            <div class="mt-12">
              <CostComparison hushboxCost={costData.monthlyCost} modelCount={modelCount} />
            </div>
            <p class="text-foreground mt-6 text-center text-sm">
              HushBox hates subscriptions. You only pay for what you use. Nothing more.
            </p>
          </ScrollReveal>

          {providers.length > 0 && (
            <ScrollReveal client:visible delay={200}>
              <div class="border-border mt-16 rounded-lg border-2 p-6">
                <ModelProviderStrip providers={providers} modelCount={modelCount} />
              </div>
            </ScrollReveal>
          )}
        </div>
      </section>
    )
  }

  {/* ===== COMPARISON TABLE ===== */}
  <section class="py-12">
    <div class="mx-auto max-w-5xl px-6">
      <ScrollReveal client:visible>
        <h2 class="text-center text-3xl font-bold tracking-tight sm:text-4xl">How we compare</h2>
        <div class="mt-12">
          <DataGrid
            client:visible
            columns={['', 'Your current AI chat app', 'HushBox']}
            rows={comparisonRows}
            highlightColumn={2}
            animated
          />
        </div>
      </ScrollReveal>
    </div>
  </section>

  {/* ===== FEATURES ===== */}
  <section class="py-12">
    <div class="mx-auto max-w-5xl px-6">
      <ScrollReveal client:visible>
        <h2 class="text-center text-3xl font-bold tracking-tight sm:text-4xl">
          Everything you need
        </h2>
        <div class="mt-12 grid grid-cols-2 gap-3 sm:grid-cols-3">
          {
            SHIPPED_FEATURES.map((f) => (
              <FeatureCard name={f.name} description={f.description}>
                <img slot="icon" src={iconPath(f.lucideIcon)} width="16" height="16" alt="" />
              </FeatureCard>
            ))
          }
        </div>
        <p class="text-foreground mt-10 text-center text-sm font-semibold">Coming Soon</p>
        <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-4">
          {
            COMING_SOON_FEATURES.map((f) => (
              <FeatureCard name={f.name} comingSoon>
                <img slot="icon" src={iconPath(f.lucideIcon)} width="16" height="16" alt="" />
              </FeatureCard>
            ))
          }
        </div>
      </ScrollReveal>
    </div>
  </section>

  {/* ===== TRANSPARENT PRICING ===== */}
  <section class="py-12">
    <div class="mx-auto max-w-5xl px-6">
      <ScrollReveal client:visible>
        <h2 class="text-center text-3xl font-bold tracking-tight sm:text-4xl">
          Transparent pricing
        </h2>
        <div class="mx-auto mt-12 grid max-w-2xl items-center gap-8 sm:grid-cols-2">
          <FeeBreakdown client:load depositAmount={10} />
          <CostPieChart client:load depositAmount={10} />
        </div>
      </ScrollReveal>
    </div>
  </section>

  {/* ===== FINAL CTA ===== */}
  <section class="py-12">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Ready to chat privately?</h2>
      <div class="mt-8">
        <a href={ROUTES.CHAT} class={buttonVariants({ size: 'lg' })}> Try HushBox Free </a>
      </div>
      <p class="text-foreground mt-4 text-sm">No account required.</p>
    </div>
  </section>

  <SiteFooter />
</LandingLayout>
