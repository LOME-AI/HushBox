  {/* ===== TRANSPARENT PRICING ===== */}
  <section class="py-12">
    <div class="mx-auto max-w-5xl px-6">
      <ScrollReveal client:visible>
        <h2 class="text-center text-3xl font-bold tracking-tight sm:text-4xl">
