---
interface Props {
  title: string;
  description: string;
  as?: 'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6';
}

const { title, description, as = 'h2' } = Astro.props;
const Heading = as;
---

<div class="border-border rounded-lg border-2 p-6 sm:p-8">
  <Heading class="text-lg font-bold tracking-tight sm:text-xl">{title}</Heading>
  <p class="text-foreground mt-3 font-serif text-sm leading-relaxed sm:text-base">
    {description}
  </p>
</div>
