---
interface Props {
  name: string;
  description?: string;
  comingSoon?: boolean;
}

const { name: featureName, description, comingSoon = false } = Astro.props;
const hasIcon = Astro.slots.has('icon');
---

<div
  class={`rounded-lg border-2 px-4 py-3 ${comingSoon ? 'border-dashed border-border text-foreground' : 'border-border'}`}
>
  <div>
    <p class="flex items-center text-sm font-medium">
      <span>
        {featureName}
        {comingSoon && <span class="text-foreground/60 ml-1 text-xs font-normal">(soon)</span>}
      </span>
      {
        hasIcon && (
          <span class="text-primary ml-auto shrink-0 [&>svg]:h-4 [&>svg]:w-4">
            <slot name="icon" />
          </span>
        )
      }
    </p>
    {description && <p class="text-foreground/70 mt-1 text-xs">{description}</p>}
  </div>
</div>
