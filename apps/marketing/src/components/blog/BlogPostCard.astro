---
import type { BlogPost } from '../../lib/blog';
import { Badge } from '@hushbox/ui';
import { getReadingTime, formatPostDate } from '../../lib/blog';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const { id: slug, data, body } = post;
const { title, description, author, date, tags } = data;

const formattedDate = formatPostDate(date, 'short');
---

<a
  href={`/blog/${slug}`}
  class="border-border bg-card hover:border-brand-red group flex flex-col rounded-xl border-2 p-6 transition-colors"
>
  <h3
    class="text-brand-red group-hover:text-brand-red-hover text-lg font-semibold transition-colors"
  >
    {title}
  </h3>

  <p class="text-foreground-muted mt-2 line-clamp-2 text-sm">{description}</p>

  <div class="mt-auto pt-4">
    <div class="text-foreground-muted flex items-center gap-2 text-xs">
      <span>{author}</span>
      <span aria-hidden="true">&middot;</span>
      <time datetime={date.toISOString()}>{formattedDate}</time>
      <span aria-hidden="true">&middot;</span>
      <span>{getReadingTime(body ?? '')} min read</span>
    </div>

    {
      tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-1.5">
          {tags.map((tag) => (
            <Badge variant="secondary" className="text-xs">
              {tag}
            </Badge>
          ))}
        </div>
      )
    }
  </div>
</a>
