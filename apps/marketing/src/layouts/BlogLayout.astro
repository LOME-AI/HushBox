---
import ThemeScript from '../components/ThemeScript.astro';
import BaseBody from '../components/BaseBody.astro';
import faviconUrl from '@hushbox/ui/assets/favicon.ico';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  author?: string;
  date?: Date;
  tags?: string[];
  image?: string | undefined;
}

const { title, description, author, date, tags, image } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = image ?? `${String(Astro.site ?? 'https://hushbox.ai')}og-default.png`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | HushBox Blog</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | HushBox Blog`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={date ? 'article' : 'website'} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="HushBox" />
    {date && <meta property="article:published_time" content={date.toISOString()} />}
    {author && <meta property="article:author" content={author} />}
    {tags?.map((tag) => <meta property="article:tag" content={tag} />)}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="HushBox Blog" href="/rss.xml" />

    <link rel="icon" type="image/x-icon" href={faviconUrl} />
    <ThemeScript />

    {
      date && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify({
            '@context': 'https://schema.org',
            '@type': 'Article',
            headline: title,
            description,
            datePublished: date.toISOString(),
            author: { '@type': 'Person', name: author ?? 'HushBox Team' },
            publisher: {
              '@type': 'Organization',
              name: 'HushBox',
              url: 'https://hushbox.ai',
            },
            mainEntityOfPage: canonicalUrl,
          })}
        />
      )
    }
  </head>
  <BaseBody>
    <slot />
  </BaseBody>
</html>
