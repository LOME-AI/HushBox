{
  "name": "@hushbox/marketing",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "tsx ../../scripts/with-env.ts astro build",
    "preview": "astro preview",
    "lint": "eslint .",
    "typecheck": "astro check && tsgo --noEmit -p tsconfig.tests.json",
    "test": "tsx ../../scripts/with-env.ts vitest run --passWithNoTests",
    "test:watch": "tsx ../../scripts/with-env.ts vitest",
    "test:coverage": "tsx ../../scripts/with-env.ts vitest run --coverage"
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.2",
    "@astrojs/react": "^5.0.7",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@hushbox/crypto": "workspace:*",
    "@hushbox/shared": "workspace:*",
    "@hushbox/ui": "workspace:*",
    "astro": "^6.4.4",
    "lucide-react": "^1.17.0",
    "lucide-static": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@hushbox/config": "workspace:*",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "vitest": "^4.1.8"
  }
}
