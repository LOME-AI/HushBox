#!/bin/bash
# Load environment variables for local development and CI
# Sources backend vars (.dev.vars), frontend vars (.env.development), and scripts vars (.env.scripts)
set -a
source "$(dirname "$0")/../apps/api/.dev.vars"
source "$(dirname "$0")/../.env.development"
source "$(dirname "$0")/../.env.scripts"
set +a

# Node 25 ships an experimental localStorage stub that conflicts with jsdom's
# Storage in tests; disable it so jsdom owns the Storage globals.
export NODE_OPTIONS="${NODE_OPTIONS:+$NODE_OPTIONS }--no-experimental-webstorage"

exec "$@"
