{
  "name": "hushbox",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.26.0",
  "scripts": {
    "dev": "pnpm generate:env && ./scripts/with-env tsx scripts/dev.ts",
    "dev:clean": "./scripts/with-env sh -c 'lsof -t -i:${HB_VITE_PORT} -i:${HB_API_PORT} | xargs -r kill -9 || true'",
    "dev:restart": "pnpm dev:clean && pnpm dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:fix": "turbo lint --force --continue -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo typecheck",
    "test": "./scripts/with-env turbo test",
    "test:all": "./scripts/with-env turbo test --continue",
    "test:api": "./scripts/with-env turbo test --filter=@hushbox/api",
    "test:web": "./scripts/with-env turbo test --filter=@hushbox/web",
    "test:crypto": "./scripts/with-env turbo test --filter=@hushbox/crypto",
    "test:shared": "./scripts/with-env turbo test --filter=@hushbox/shared",
    "test:db": "./scripts/with-env turbo test --filter=@hushbox/db",
    "test:realtime": "./scripts/with-env turbo test --filter=@hushbox/realtime",
    "test:ui": "./scripts/with-env turbo test --filter=@hushbox/ui",
    "test:watch": "./scripts/with-env vitest",
    "test:watch:ui": "./scripts/with-env vitest --ui",
    "test:coverage": "./scripts/with-env turbo test:coverage",
    "preview": "pnpm generate:env && ./scripts/with-env sh -c 'pnpm --filter @hushbox/web build --mode development && pnpm --filter @hushbox/api dev & pnpm --filter @hushbox/web preview --port ${HB_PREVIEW_PORT} --open'",
    "open:preview": "./scripts/with-env sh -c 'xdg-open http://localhost:${HB_PREVIEW_PORT} 2>/dev/null || open http://localhost:${HB_PREVIEW_PORT}'",
    "e2e:kill-servers": "./scripts/with-env sh -c 'lsof -t -i:${HB_PREVIEW_PORT} -i:${HB_API_PORT} | xargs -r kill -9 2>/dev/null || true'",
    "e2e": "pnpm e2e:kill-servers && ./scripts/with-env playwright test",
    "e2e:quick": "pnpm e2e:kill-servers && ./scripts/with-env playwright test --project=chromium --project=iphone-15",
    "e2e:fast": "pnpm e2e:kill-servers && ./scripts/with-env playwright test --project=iphone-15 --retries=0",
    "e2e:failed": "pnpm e2e:kill-servers && ./scripts/with-env playwright test --last-failed",
    "e2e:auth": "pnpm e2e:kill-servers && ./scripts/with-env playwright test e2e/auth/ --project=chromium",
    "e2e:chat": "pnpm e2e:kill-servers && ./scripts/with-env playwright test e2e/chat/ --project=chromium",
    "e2e:billing": "pnpm e2e:kill-servers && ./scripts/with-env playwright test e2e/billing/ --project=chromium",
    "e2e:sharing": "pnpm e2e:kill-servers && ./scripts/with-env playwright test e2e/sharing/ --project=chromium",
    "e2e:group": "pnpm e2e:kill-servers && ./scripts/with-env playwright test e2e/group/ --project=chromium",
    "e2e:ui": "pnpm e2e:kill-servers && ./scripts/with-env playwright test e2e/ui/ --project=chromium",
    "e2e:mobile": "pnpm e2e:kill-servers && ./scripts/with-env playwright test e2e/mobile/ --project=iphone-15",
    "e2e:api": "pnpm e2e:kill-servers && ./scripts/with-env playwright test e2e/api/ --project=chromium",
    "clean": "turbo clean && rm -rf node_modules",
    "prepare": "husky",
    "docker:cleanup": "./scripts/with-env tsx scripts/docker-cleanup.ts",
    "db:up": "./scripts/with-env docker compose up -d --wait postgres neon-proxy redis serverless-redis-http",
    "db:down": "./scripts/with-env docker compose down",
    "db:reset": "./scripts/with-env tsx scripts/db-reset.ts",
    "db:migrate": "./scripts/with-env pnpm --filter @hushbox/db db:migrate",
    "db:generate": "./scripts/with-env pnpm --filter @hushbox/db db:generate",
    "db:studio": "./scripts/with-env pnpm --filter @hushbox/db db:studio",
    "db:seed": "./scripts/with-env tsx scripts/seed.ts",
    "generate:env": "tsx scripts/generate-env.ts",
    "verify:env": "tsx scripts/verify-env.ts",
    "verify:typecheck-coverage": "tsx scripts/verify-typecheck-coverage.ts",
    "verify:evidence": "./scripts/with-env tsx scripts/verify-evidence.ts",
    "generate:icons": "tsx scripts/readme/generate-icons.ts",
    "generate:banner": "tsx scripts/readme/generate-banner.ts",
    "generate:tables": "tsx scripts/readme/generate-tables.ts",
    "generate:problem-flow": "tsx scripts/readme/generate-problem-flow.ts",
    "generate:readme": "pnpm generate:icons && pnpm generate:banner && pnpm generate:tables && pnpm generate:problem-flow && tsx scripts/readme/generate-readme.ts",
    "preview:readme": "./scripts/with-env tsx scripts/readme/preview-readme.ts",
    "asset:generate": "tsx scripts/generate-assets.ts",
    "asset:sync": "pnpm --filter web asset:sync",
    "asset:build": "pnpm asset:generate && pnpm asset:sync",
    "screenshot:generate": "tsx scripts/generate-screenshots.ts",
    "lint:duplication": "jscpd --threshold 2 --silent .",
    "lint:unused": "./scripts/with-env knip --no-progress",
    "lint:summary": "turbo lint --continue -- --format summary",
    "lint:check": "tsx scripts/lint-check.ts",
    "mutation": "./scripts/with-env stryker run",
    "mutation:incremental": "./scripts/with-env stryker run --incremental",
    "cap:test-update": "./scripts/with-env tsx scripts/cap-test-update.ts",
    "mobile:up": "./scripts/with-env docker compose --profile mobile up -d android-emulator",
    "mobile:down": "./scripts/with-env docker compose --profile mobile down",
    "mobile:test": "./scripts/with-env tsx scripts/mobile-test.ts",
    "mobile:test:smoke": "./scripts/with-env tsx scripts/mobile-test.ts --smoke",
    "mobile:studio": "maestro studio",
    "mobile:vnc": "./scripts/with-env sh -c 'echo \"Opening emulator VNC at http://localhost:${HB_EMULATOR_VNC_PORT}\" && xdg-open http://localhost:${HB_EMULATOR_VNC_PORT} 2>/dev/null || open http://localhost:${HB_EMULATOR_VNC_PORT}'"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@hushbox/crypto": "workspace:*",
    "@hushbox/db": "workspace:*",
    "@hushbox/shared": "workspace:*",
    "@napi-rs/canvas": "^0.1.97",
    "@playwright/test": "^1.58.2",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@types/seedrandom": "^3.0.8",
    "@typescript/native-preview": "7.0.0-dev.20260409.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-summary": "^2.0.2",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-sonarjs": "^4.0.1",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "execa": "^9.6.1",
    "gif-encoder-2": "^1.0.5",
    "github-markdown-css": "^5.9.0",
    "globals": "^17.4.0",
    "highlight.js": "^11.11.1",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "knip": "^5.86.0",
    "lucide-static": "^1.8.0",
    "marked": "^18.0.0",
    "marked-alert": "^2.1.2",
    "marked-highlight": "^2.2.4",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "seedrandom": "^3.0.5",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.15",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.2",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "vite": "^7.3.2",
      "sharp": "^0.34.5"
    }
  }
}
