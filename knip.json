{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    "apps/api": {
      "project": ["src/**/*.ts"]
    },
    "apps/web": {
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["@capacitor/ios"]
    },
    "packages/shared": {
      "project": ["src/**/*.ts"]
    },
    "packages/db": {
      "project": ["src/**/*.ts"]
    },
    "packages/ui": {
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["onnxruntime-web"]
    },
    "packages/config": {
      "project": ["**/*.{js,ts}"],
      "ignore": ["import-meta-env.d.ts"]
    },
    "scripts": {
      "entry": ["*.ts", "!*.test.ts", "lib/idle-killer-daemon-entry.ts"],
      "project": ["**/*.ts"]
    },
    "ops": {
      "entry": ["**/*.ts", "!**/*.test.ts"],
      "project": ["**/*.ts"]
    },
    "e2e": {
      "entry": [
        "fixtures.ts",
        "auth.setup.ts",
        "global-setup.ts",
        "global-teardown.ts",
        "**/*.spec.ts"
      ],
      "project": ["**/*.ts"]
    },
    "packages/realtime": {
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["cloudflare"]
    },
    "apps/marketing": {
      "entry": ["src/pages/**/*.astro"],
      "project": ["src/**/*.{astro,ts,tsx}"],
      "ignoreDependencies": ["zod"]
    }
  },
  "ignore": [".claude/**"],
  "ignoreDependencies": [
    "eslint-formatter-summary",
    "github-markdown-css",
    "tailwindcss",
    "tw-animate-css",
    "css-select",
    "css-tree",
    "domutils",
    "htmlparser2"
  ],
  "ignoreBinaries": ["maestro", "adb", "cap", "wrangler", "drizzle-kit", "tar"],
  "ignoreExportsUsedInFile": true,
  "playwright": {
    "config": [
      "playwright.config.{js,ts,mjs}",
      "playwright-ct.config.{js,ts,mjs}"
    ]
  }
}
