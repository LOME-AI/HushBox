#!/bin/sh
[ -f .husky/pre-commit.local ] && . .husky/pre-commit.local
pnpm generate:readme
git add README.md \
  .github/readme/banner-dark.gif \
  .github/readme/banner-light.gif \
  .github/readme/*.svg \
  .github/readme/.cache \
  packages/ui/src/assets/icons
pnpm generate:env
git add apps/api/wrangler.toml \
  .github/workflows/ci.yml \
  .github/workflows/release.yml \
  .github/workflows/build-android.yml \
  .github/workflows/run-ops-script.yml
pnpm generate:ops-dispatch
git add .github/workflows/run-ops-script.yml
pnpm --filter @hushbox/db db:generate
git add packages/db/drizzle
pnpm seed:cache
git add scripts/.cache/seed-crypto