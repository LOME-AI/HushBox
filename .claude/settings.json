{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "0"
  },
  "permissions": {
    "allow": [
      "mcp__linear-server",
      "Bash(pnpm test)",
      "Bash(pnpm test:*)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm lint)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm ensure-stack)",
      "Bash(pnpm ensure-stack:*)",
      "Bash(pnpm e2e)",
      "Bash(pnpm e2e:*)",
      "Bash(turbo:*)",
      "Bash(jscpd:*)",
      "Bash(tsgo:*)",
      "Bash(eslint:*)",
      "Bash(vitest:*)",
      "Bash(git diff:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git log:*)"
    ],
    "deny": [
      "Bash(git stash:*)",
      "Bash(git checkout -- :*)",
      "Bash(git checkout .:*)",
      "Bash(git restore:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "mcp__linear-server__delete_*",
      "mcp__linear-server__remove_*"
    ]
  }
}
