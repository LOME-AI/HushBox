{
  "name": "@hushbox/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./zod": "./src/zod/index.ts",
    "./factories": "./src/factories/index.ts"
  },
  "scripts": {
    "db:generate": "tsx ../../scripts/with-env.ts drizzle-kit generate",
    "db:migrate": "tsx ../../scripts/with-env.ts drizzle-kit migrate",
    "db:push": "tsx ../../scripts/with-env.ts drizzle-kit push",
    "db:studio": "tsx ../../scripts/with-env.ts tsx ../../scripts/drizzle-studio.ts",
    "test": "tsx ../../scripts/with-env.ts vitest run",
    "test:watch": "tsx ../../scripts/with-env.ts vitest",
    "test:coverage": "tsx ../../scripts/with-env.ts vitest run --coverage",
    "lint": "eslint .",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@hushbox/shared": "workspace:*",
    "@neondatabase/serverless": "^1.0.2",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@hushbox/config": "workspace:*",
    "@hushbox/crypto": "workspace:*",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.9",
    "fishery": "^2.4.0",
    "pg": "^8.20.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
