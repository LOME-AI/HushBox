# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
dist-ota/
build/
out/
.next/
.vercel/
.wrangler/
apps/api/.wrangler-*.log
.astro/

# TypeScript
*.tsbuildinfo

# Turbo
.turbo/

# Environment files (auto-generated by pnpm generate:env)
.env
.env.local
.env.*.local
.env.development
.env.scripts
.dev.vars

# Test fixtures (generated by vitest, cleaned up in afterEach)
**/__test-fixtures-*__/

# Test coverage
coverage/
.nyc_output/

# HTTP cassettes for AI Gateway integration tests (recorded by CI, restored
# via actions/cache; never committed). See docs/CI-CASSETTES.md.
.ai-cassettes/

# Quality reports
/reports/
.stryker-cache/

# Playwright
playwright-report/
test-results/
# e2e-clean.ts renames a wedged output dir aside as test-results.purge-<n> before each run
test-results.purge-*/
e2e/.auth/
e2e/report/

# Maestro
maestro-results/

# Logs
*.log
pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE
/.idea
.vscode/
*.swp
*.swo

# Claude Code
/.claude/settings.local.json
/.claude/scheduled_tasks.lock

# Local overrides
*.local*
/*Local

# Capacitor
apps/web/ios/App/Pods/
apps/web/android/.gradle/
apps/web/android/app/build/
apps/web/public/dev-assets/

# Temporary files
*.tmp
*.temp
.cache/
# README generation hashes are deliberately committed so CI and fresh clones
# skip expensive regeneration when inputs haven't changed.
!.github/readme/.cache/
# Seed-crypto cache is committed: produced by `pnpm seed:cache` (auto-run from
# pre-commit when crypto/personas change). Lets CI seed in ~6s on every run.
!scripts/.cache/
!scripts/.cache/seed-crypto/

# TanStack Router
.tanstack/
